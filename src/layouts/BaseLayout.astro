---
interface Props {
  title?: string; description?: string; ogImage?: string; canonical?: string;
  metadata?: { title?: string; description?: string; ogImage?: string; canonical?: string; ignoreTitleTemplate?: boolean; };
}
import Seo from "../components/seo/Seo.astro";
import Schema from "../components/seo/Schema.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import "../styles/global.css";
import { siteConfig } from "../config/site";
import { getTexts, txt, getHeroSettings } from "../lib/content";

const { title, description, ogImage, canonical, metadata } = Astro.props;
const finalTitle = metadata?.title || title;
const finalDescription = metadata?.description || description;
const finalOgImage = metadata?.ogImage || ogImage;
const finalCanonical = metadata?.canonical || canonical;
const finalIgnoreTitleTemplate = metadata?.ignoreTitleTemplate || false;

// Zámek webu — když je zapnutý, veřejné stránky ukážou jen úvodní fotku + text.
let locked = false;
let lockText = "";
let lockName = siteConfig.name;
let lockHeroStyle = "background-image:url('/hero.jpg');background-size:cover;background-position:center;";
try {
  const t = await getTexts();
  locked = txt(t, "site_locked", "") === "1";
  if (locked) {
    lockText = txt(t, "lock_text", "");
    lockName = txt(t, "site_name", siteConfig.name);
    const hero = await getHeroSettings();
    lockHeroStyle = `background-image:url('${hero.imageUrl}');background-size:${hero.fit};background-position:${hero.position};`;
  }
} catch {
  /* D1 nedostupné (prerender) — web se nezamyká */
}
---

<!doctype html>
<html lang={siteConfig.lang} class="scroll-smooth">
  <head>
    <Seo title={finalTitle} description={finalDescription} ogImage={finalOgImage} canonical={finalCanonical} ignoreTitleTemplate={finalIgnoreTitleTemplate} />
    <Schema type="WebSite" data={{}} />
    <Font cssVariable="--font-inter" preload />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="bg-background text-foreground antialiased tracking-tight">
    {
      locked ? (
        <section class="lock-screen">
          <div class="lock-bg" style={lockHeroStyle} aria-hidden="true" />
          <div class="lock-overlay" aria-hidden="true" />
          <div class="lock-content">
            <h1 class="lock-name">{lockName}</h1>
            {lockText && <p class="lock-text">{lockText}</p>}
          </div>
        </section>
      ) : (
        <Fragment>
          <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-50 rounded-md bg-primary px-4 py-2 text-white"
          >
            Přeskočit
          </a>
          <div
            class="pointer-events-none fixed inset-0 z-0 bg-cover bg-center bg-no-repeat opacity-10"
            style="background-image: url('/bg.jpg');"
            aria-hidden="true"
          />
          <div class="relative z-10 flex min-h-screen flex-col overflow-x-hidden">
            <Navbar />
            <main id="main-content" class="relative grow">
              <slot />
            </main>
            <Footer />
          </div>
        </Fragment>
      )
    }

    <button
      id="to-top"
      type="button"
      aria-label="Nahoru na začátek stránky"
      title="Nahoru"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M12 19V5M5 12l7-7 7 7"></path>
      </svg>
    </button>

    <style>
      /* Zámek webu — celá obrazovka: fotka + ztmavení + vycentrovaný text. */
      .lock-screen {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }
      .lock-bg {
        position: absolute;
        inset: 0;
        background-repeat: no-repeat;
      }
      .lock-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgb(0 0 0 / 0.85),
          rgb(0 0 0 / 0.5)
        );
      }
      .lock-content {
        position: relative;
        z-index: 1;
        max-width: 40rem;
        padding: 2rem;
        text-align: center;
        color: #fff;
      }
      .lock-name {
        font-size: clamp(2rem, 6vw, 3.5rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }
      .lock-text {
        font-size: clamp(1rem, 2.5vw, 1.25rem);
        line-height: 1.6;
        color: rgb(255 255 255 / 0.85);
        white-space: pre-line;
      }

      #to-top {
        position: fixed;
        right: 1.5rem;
        bottom: 1.5rem;
        z-index: 40;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 9999px;
        color: var(--foreground, #111);
        background: color-mix(in srgb, var(--background, #fff) 80%, transparent);
        border: 1px solid var(--border, #e5e5e5);
        backdrop-filter: blur(6px);
        opacity: 0;
        transform: translateY(0.5rem);
        pointer-events: none;
        transition:
          opacity 0.25s ease,
          transform 0.25s ease,
          background-color 0.2s ease;
      }
      #to-top.show {
        opacity: 0.55;
        transform: translateY(0);
        pointer-events: auto;
      }
      #to-top.show:hover {
        opacity: 1;
      }
      #to-top svg {
        width: 1.15rem;
        height: 1.15rem;
      }
      @media (prefers-reduced-motion: reduce) {
        #to-top {
          transition: opacity 0.2s ease;
          transform: none;
        }
      }
    </style>

    <script>
      // Decentní tlačítko „nahoru" — objeví se po odscrollování, plynule vyjede nahoru.
      function setupToTop() {
        const btn = document.getElementById("to-top");
        if (!btn) return;
        const onScroll = () => {
          btn.classList.toggle("show", window.scrollY > 500);
        };
        if (!btn.dataset.bound) {
          btn.dataset.bound = "1";
          btn.addEventListener("click", () =>
            window.scrollTo({ top: 0, behavior: "smooth" }),
          );
        }
        // Posluchač scrollu navěšujeme jen jednou na okno.
        const w = window as unknown as { __toTopBound?: boolean };
        if (!w.__toTopBound) {
          w.__toTopBound = true;
          window.addEventListener("scroll", onScroll, { passive: true });
        }
        onScroll();
      }
      setupToTop();
      document.addEventListener("astro:page-load", setupToTop);
    </script>

    <script>
      function setupReveal() {
        const vh = window.innerHeight;
        document.querySelectorAll(".reveal:not(.active)").forEach(el => {
          const rect = el.getBoundingClientRect();
          if (rect.top < vh + 60) el.classList.add("active");
        });
        document.documentElement.classList.add("reveal-ready");
        const obs = new IntersectionObserver((entries, o) => {
          entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add("active"); o.unobserve(e.target); } });
        }, { rootMargin: "0px 0px -60px 0px", threshold: 0.1 });
        document.querySelectorAll(".reveal:not(.active)").forEach(el => obs.observe(el));
      }
      setupReveal();
      document.addEventListener("astro:page-load", setupReveal);
      document.addEventListener("astro:after-swap", () => {
        document.querySelectorAll(".reveal").forEach(el => el.classList.add("active"));
      });
    </script>
  </body>
</html>
