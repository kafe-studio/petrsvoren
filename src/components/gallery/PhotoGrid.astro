---
// Mřížka fotek + velký náhled (lightbox). Náhled vyplní okno prohlížeče (fotka +
// filmový pás), nic nepřesahuje a nejsou tam žádné posuvníky. Funkce:
//   • listování ←/→ a bočními šipkami (dokola), počítadlo X / N
//   • plná velikost (klik na fotku / lupa → třída lb-full: skryje pás i popisek,
//     fotka dostane celé okno); stav se drží i při listování
//   • pás náhledů sekce pod fotkou (jen v náhledu): krytí 5 %, hover plný jas,
//     klik = přepne fotku; roztažený na šířku okna, aktuální zvýrazněná
//   • posuvník pozadí černá→bílá (jen myší; --lb-bg/--lb-fg na <html>, localStorage)
//   • zavření křížkem / Esc
// Podrobnosti a možnosti úprav: docs/FOTOSABLONA.md (sekce „Velký náhled").
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  photos: CollectionEntry<"photos">[];
}

const { photos } = Astro.props;

const items = photos.map((photo, index) => ({
  photo,
  dialogId: `photo-${index}`,
}));
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
  {
    items.map(({ photo, dialogId }, index) => (
      <figure class="reveal">
        <button
          type="button"
          data-dialog-open={dialogId}
          class="group block w-full cursor-pointer"
          aria-label={`Zobrazit detail: ${photo.data.caption}`}
        >
          <span class="block overflow-hidden bg-muted">
            <Image
              src={photo.data.cover}
              alt={photo.data.coverAlt ?? photo.data.caption}
              widths={[400, 800]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              loading="lazy"
              class="block w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </span>
        </button>
        <figcaption class="mt-3 text-sm text-muted-foreground">{photo.data.caption}</figcaption>

        <dialog
          id={dialogId}
          data-lightbox
          data-index={index}
          class="lb-dialog backdrop:bg-black/85"
        >
          <div class="lb-bar flex shrink-0 items-center gap-3 px-3 py-2">
            <span class="shrink-0 text-xs tabular-nums opacity-60">{index + 1} / {items.length}</span>
            <label class="flex min-w-0 flex-1 items-center justify-center" title="Pozadí náhledu: černá → bílá">
              <span class="sr-only">Pozadí náhledu od černé po bílou</span>
              <input
                type="range"
                min="0"
                max="100"
                step="1"
                value="6"
                data-lb-bg
                tabindex="-1"
                class="lb-range w-full max-w-56"
                aria-label="Pozadí náhledu od černé po bílou (jen myší)"
              />
            </label>
            <div class="flex shrink-0 items-center gap-1">
              <button
                type="button"
                data-zoom
                class="rounded-full p-2 opacity-70 transition hover:opacity-100"
                aria-label="Přepnout plnou velikost"
                title="Plná velikost"
              >
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 9V5a1 1 0 011-1h4M20 9V5a1 1 0 00-1-1h-4M4 15v4a1 1 0 001 1h4M20 15v4a1 1 0 01-1 1h-4" />
                </svg>
              </button>
              <form method="dialog" class="contents">
                <button
                  type="submit"
                  class="rounded-full p-2 opacity-70 transition hover:opacity-100"
                  aria-label="Zavřít"
                >
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </form>
            </div>
          </div>

          <button type="button" data-zoom class="lb-stage" aria-label="Přepnout plnou velikost">
            <Image
              src={photo.data.cover}
              alt={photo.data.coverAlt ?? photo.data.caption}
              widths={[800, 1600]}
              sizes="100vw"
              loading="lazy"
              class="lb-img"
            />
          </button>

          <p class="lb-caption shrink-0 px-4 pb-1 pt-2 text-center text-sm font-medium">{photo.data.caption}</p>

          <nav class="lb-strip flex shrink-0 gap-1 px-2 pb-2" aria-label="Fotky v sekci">
            {items.map((it, i) => (
              <button
                type="button"
                data-go={i}
                class:list={["lb-thumb min-w-0 flex-1 overflow-hidden rounded-sm", { "is-current": i === index }]}
                aria-label={`Fotka ${i + 1}: ${it.photo.data.caption}`}
                aria-current={i === index ? "true" : undefined}
              >
                <Image
                  src={it.photo.data.cover}
                  alt=""
                  widths={[120, 240]}
                  sizes="160px"
                  loading="lazy"
                  class="block h-12 w-full object-cover sm:h-14"
                />
              </button>
            ))}
          </nav>

          <button
            type="button"
            data-nav="prev"
            class="fixed left-2 top-1/2 z-30 -translate-y-1/2 rounded-full bg-black/30 p-2 text-white/70 backdrop-blur-sm transition hover:bg-black/50 hover:text-white sm:left-4"
            aria-label="Předchozí fotka"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button
            type="button"
            data-nav="next"
            class="fixed right-2 top-1/2 z-30 -translate-y-1/2 rounded-full bg-black/30 p-2 text-white/70 backdrop-blur-sm transition hover:bg-black/50 hover:text-white sm:right-4"
            aria-label="Další fotka"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </dialog>
      </figure>
    ))
  }
</div>

<script>
  function lockScroll(on: boolean) {
    document.documentElement.style.overflow = on ? "hidden" : "";
  }

  // Plná velikost = skryje pás i popisek, fotka dostane celé okno (zůstává v okně).
  function setZoom(dlg: HTMLDialogElement, on: boolean) {
    dlg.classList.toggle("lb-full", on);
  }

  // Pozadí náhledu: 0 = černá … 100 = bílá. Nastaví proporcionální šeď + kontrastní text.
  function applyLightboxBg(value: number) {
    const g = Math.round((value / 100) * 255);
    const root = document.documentElement.style;
    root.setProperty("--lb-bg", `rgb(${g}, ${g}, ${g})`);
    root.setProperty("--lb-fg", g < 140 ? "#f2f2f2" : "#161616");
  }

  // Otevře lightbox dané fotky a zavře případný jiný otevřený.
  // full = true zobrazí fotku rovnou v plné velikosti (využije se při listování).
  function openLightbox(index: number, full = false) {
    const dlg = document.getElementById(`photo-${index}`) as HTMLDialogElement | null;
    if (!dlg) return;
    document
      .querySelectorAll<HTMLDialogElement>("dialog[data-lightbox][open]")
      .forEach((d) => {
        if (d !== dlg) d.close();
      });
    if (!dlg.open) dlg.showModal();
    setZoom(dlg, full);
    lockScroll(true);
  }

  // Posun na předchozí/další fotku (wrap-around) podle aktuálně otevřeného.
  // Když je aktuální fotka v plné velikosti, další se zobrazí rovnou taky v plné velikosti.
  function step(delta: number) {
    const open = document.querySelector<HTMLDialogElement>("dialog[data-lightbox][open]");
    if (!open) return;
    const wasFull = open.classList.contains("lb-full");
    const total = document.querySelectorAll("dialog[data-lightbox]").length;
    const idx = Number(open.dataset.index);
    openLightbox((idx + delta + total) % total, wasFull);
  }

  function setupLightbox() {
    document.querySelectorAll<HTMLElement>("[data-dialog-open]").forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = "1";
      const id = btn.getAttribute("data-dialog-open");
      const index = id ? Number(id.replace("photo-", "")) : NaN;
      btn.addEventListener("click", () => openLightbox(index));
    });

    document.querySelectorAll<HTMLElement>("[data-nav]").forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => step(btn.dataset.nav === "next" ? 1 : -1));
    });

    document.querySelectorAll<HTMLElement>("[data-zoom]").forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {
        const dlg = btn.closest("dialog") as HTMLDialogElement | null;
        if (dlg) setZoom(dlg, !dlg.classList.contains("lb-full"));
      });
    });

    // Klik na náhled v pásu → zobraz tu fotku (zůstává v náhledu).
    document.querySelectorAll<HTMLElement>("[data-go]").forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => openLightbox(Number(btn.dataset.go)));
    });

    // Posuvník pozadí (černá → bílá). Hodnota je globální + uložená v localStorage.
    let stored = 6;
    try {
      const raw = localStorage.getItem("lb-bg");
      if (raw !== null && Number.isFinite(Number(raw))) stored = Number(raw);
    } catch {}
    applyLightboxBg(stored);
    document.querySelectorAll<HTMLInputElement>("[data-lb-bg]").forEach((slider) => {
      slider.value = String(stored);
      if (slider.dataset.bound) return;
      slider.dataset.bound = "1";
      slider.addEventListener("input", () => {
        const v = Number(slider.value);
        applyLightboxBg(v);
        try {
          localStorage.setItem("lb-bg", String(v));
        } catch {}
        document
          .querySelectorAll<HTMLInputElement>("[data-lb-bg]")
          .forEach((other) => {
            if (other !== slider) other.value = String(v);
          });
      });
    });

    document.querySelectorAll<HTMLDialogElement>("dialog[data-lightbox]").forEach((dlg) => {
      if (dlg.dataset.bound) return;
      dlg.dataset.bound = "1";
      // Klik na pozadí (mimo obsah) zavře dialog.
      dlg.addEventListener("click", (e) => {
        if (e.target === dlg) dlg.close();
      });
      // Scroll odemkni jen když není otevřený žádný jiný lightbox (kvůli listování).
      dlg.addEventListener("close", () => {
        if (!document.querySelector("dialog[data-lightbox][open]")) lockScroll(false);
      });
    });
  }

  // Klávesy ←/→ registruj jen jednou (přežije soft-navigaci ClientRouteru).
  const w = window as unknown as { __lightboxKeys?: boolean };
  if (!w.__lightboxKeys) {
    w.__lightboxKeys = true;
    document.addEventListener("keydown", (e) => {
      if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
      if (!document.querySelector("dialog[data-lightbox][open]")) return;
      // Šipky vždy listují mezi fotkami (i když má fokus posuvník — ten je jen pro myš).
      e.preventDefault();
      step(e.key === "ArrowRight" ? 1 : -1);
    });
  }

  document.addEventListener("astro:page-load", setupLightbox);
</script>

<style>
  /* Lightbox vyplní celé okno a vejde se celý — žádné posuvníky.
     Pozadí řídí posuvník přes proměnné --lb-bg / --lb-fg (na <html>). */
  .lb-dialog {
    width: 100vw;
    max-width: 100vw;
    height: 100dvh;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--lb-bg, #0a0a0f);
    color: var(--lb-fg, #ededed);
  }
  .lb-bar {
    background: color-mix(in srgb, var(--lb-bg, #0a0a0f) 88%, transparent);
  }

  /* Fotka zabere zbylé místo a celá se vejde (object-contain). */
  .lb-stage {
    flex: 1 1 0;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    overflow: hidden;
    padding: 0 0.5rem;
    cursor: zoom-in;
  }
  .lb-img {
    max-height: 100%;
    max-width: 100%;
    object-fit: contain;
  }
  dialog.lb-full .lb-stage {
    cursor: zoom-out;
  }
  /* Plná velikost: skryj pás i popisek → fotka dostane celé okno. */
  dialog.lb-full .lb-strip,
  dialog.lb-full .lb-caption {
    display: none;
  }

  /* Pás náhledů sekce — roztažený na šířku okna, nikdy nepřesahuje (žádný scroll). */
  .lb-thumb {
    opacity: 0.05; /* výchozí krytí 5 % */
    outline: 2px solid transparent;
    outline-offset: -2px;
    cursor: pointer;
    transition:
      opacity 0.15s ease,
      outline-color 0.15s ease;
  }
  .lb-thumb:hover {
    opacity: 1; /* po najetí myší se rozsvítí bez průhlednosti */
  }
  .lb-thumb.is-current {
    opacity: 1;
    outline-color: var(--lb-fg, #fff);
  }

  /* Posuvník pozadí — velmi decentní: tenká linka s krátkou svislou čárkou (jezdcem). */
  .lb-range {
    -webkit-appearance: none;
    appearance: none;
    height: 14px;
    background: transparent;
    cursor: pointer;
  }
  .lb-range::-webkit-slider-runnable-track {
    height: 1px;
    background: color-mix(in srgb, var(--lb-fg, #888) 30%, transparent);
  }
  .lb-range::-moz-range-track {
    height: 1px;
    background: color-mix(in srgb, var(--lb-fg, #888) 30%, transparent);
  }
  .lb-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 2px;
    height: 12px;
    margin-top: -5.5px; /* vycentruj čárku na 1px lince */
    border: 0;
    border-radius: 0;
    background: var(--lb-fg, #fff);
  }
  .lb-range::-moz-range-thumb {
    width: 2px;
    height: 12px;
    border: 0;
    border-radius: 0;
    background: var(--lb-fg, #fff);
  }
</style>
