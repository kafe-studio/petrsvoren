---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";

const tips = (await getCollection("tips", ({ data }) => data.active)).sort(
  (a, b) => a.data.order - b.data.order,
);

const items = await Promise.all(
  tips.map(async (tip) => {
    const { Content } = await render(tip);
    return { tip, Content };
  }),
);
---

{
  items.length > 0 && (
    <section class="py-20 px-6 border-b border-border">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-10 reveal">
          Aktuálně
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {items.map(({ tip, Content }) => (
            <article class="reveal">
              {tip.data.image && tip.data.link && (
                <a href={tip.data.link} class="group mb-4 block overflow-hidden" aria-label={tip.data.title}>
                  <Image
                    src={tip.data.image}
                    alt={tip.data.title}
                    widths={[400, 800]}
                    sizes="(min-width: 768px) 50vw, 100vw"
                    loading="lazy"
                    class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </a>
              )}
              {tip.data.image && !tip.data.link && (
                <Image
                  src={tip.data.image}
                  alt={tip.data.title}
                  widths={[400, 800]}
                  sizes="(min-width: 768px) 50vw, 100vw"
                  loading="lazy"
                  class="mb-4 w-full h-auto object-cover"
                />
              )}
              <h3 class="text-xl font-semibold tracking-tight">
                {tip.data.link ? <a href={tip.data.link} class="hover:text-primary transition-colors">{tip.data.title}</a> : tip.data.title}
              </h3>
              <div class="prose prose-neutral dark:prose-invert mt-2 max-w-none text-muted-foreground">
                <Content />
              </div>
              {tip.data.link && (
                <a
                  href={tip.data.link}
                  class="mt-3 inline-block text-sm font-medium text-foreground hover:text-primary transition-colors"
                >
                  Více →
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
