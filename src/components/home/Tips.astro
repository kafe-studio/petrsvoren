---
import { getTips, getTexts, txt } from "../../lib/content";

const tips = await getTips();
const texts = await getTexts();
const heading = txt(texts, "tips_heading", "Aktuálně");

const items = tips.map((tip) => ({
  tip,
  paras: (tip.bodyText ?? "")
    .split(/\n\s*\n/)
    .map((p) => p.trim())
    .filter(Boolean),
}));
---

{
  items.length > 0 && (
    <section class="py-20 px-6 border-b border-border">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-10 reveal">
          {heading}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {items.map(({ tip, paras }) => (
            <article class="reveal">
              {tip.imageId && tip.link && (
                <a
                  href={tip.link}
                  class="group mb-4 block overflow-hidden"
                  aria-label={tip.title}
                >
                  <img
                    src={`/img/${tip.imageId}/`}
                    alt={tip.title}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </a>
              )}
              {tip.imageId && !tip.link && (
                <img
                  src={`/img/${tip.imageId}/`}
                  alt={tip.title}
                  loading="lazy"
                  decoding="async"
                  class="mb-4 w-full h-auto object-cover"
                />
              )}
              <h3 class="text-xl font-semibold tracking-tight">
                {tip.link ? (
                  <a
                    href={tip.link}
                    class="hover:text-primary transition-colors"
                  >
                    {tip.title}
                  </a>
                ) : (
                  tip.title
                )}
              </h3>
              <div class="prose prose-neutral dark:prose-invert mt-2 max-w-none text-muted-foreground">
                {paras.map((p) => (
                  <p>{p}</p>
                ))}
              </div>
              {tip.link && (
                <a
                  href={tip.link}
                  class="mt-3 inline-block text-sm font-medium text-foreground hover:text-primary transition-colors"
                >
                  Více →
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
