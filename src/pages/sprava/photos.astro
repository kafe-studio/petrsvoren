---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb, schema } from "../../db";
import { desc } from "drizzle-orm";

let photos: (typeof schema.photos.$inferSelect)[] = [];
let dbError = "";
try {
  const db = await getDb();
  photos = await db
    .select()
    .from(schema.photos)
    .orderBy(desc(schema.photos.createdAt));
} catch (e) {
  dbError = e instanceof Error ? e.message : String(e);
}

const metadata = { title: "Fotky", description: "Správa fotografií." };
---

<AdminLayout {metadata}>
  <section>
    <div class="mx-auto max-w-5xl">
      <div class="mb-8 flex items-center justify-between gap-4">
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">
          Fotky <span class="text-muted-foreground text-2xl">({photos.length})</span>
        </h1>
        <a href="/sprava/upload/" class="btn-primary">Nahrát fotky</a>
      </div>

      {dbError && <p class="text-sm text-red-500 mb-6">{dbError}</p>}

      {
        photos.length === 0 ? (
          <p class="text-muted-foreground">
            Zatím žádné fotky. <a href="/sprava/upload/" class="underline">Nahraj první</a>.
          </p>
        ) : (
          <div id="photos-manager">
            {/* Lišta hromadných akcí */}
            <div class="mb-4 flex flex-wrap items-center gap-3 rounded-lg border border-border bg-card px-4 py-2.5">
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input type="checkbox" id="select-all" />
                Vybrat vše
              </label>
              <span id="sel-count" class="text-sm text-muted-foreground">
                Vybráno 0
              </span>
              <div class="ml-auto flex flex-wrap items-center gap-2">
                <button
                  type="button"
                  id="bulk-download"
                  class="rounded-lg border border-border px-3 py-1.5 text-sm transition-colors hover:bg-muted disabled:cursor-not-allowed disabled:opacity-40"
                  disabled
                >
                  Stáhnout
                </button>
                <button
                  type="button"
                  id="bulk-hide"
                  class="rounded-lg border border-border px-3 py-1.5 text-sm transition-colors hover:bg-muted disabled:cursor-not-allowed disabled:opacity-40"
                  disabled
                >
                  Vypnout
                </button>
                <button
                  type="button"
                  id="bulk-show"
                  class="rounded-lg border border-border px-3 py-1.5 text-sm transition-colors hover:bg-muted disabled:cursor-not-allowed disabled:opacity-40"
                  disabled
                >
                  Zapnout
                </button>
                <button
                  type="button"
                  id="bulk-delete"
                  class="rounded-lg border border-red-500/40 px-3 py-1.5 text-sm text-red-500 transition-colors hover:bg-red-500/10 disabled:cursor-not-allowed disabled:opacity-40"
                  disabled
                >
                  Smazat
                </button>
              </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
              {photos.map((p) => (
                <div
                  class="photo-tile group relative overflow-hidden rounded-sm bg-neutral-900 aspect-square"
                  data-id={p.id}
                  data-hidden={p.hidden ? "1" : ""}
                >
                  <a href={`/sprava/photos/${p.id}/`} class="block h-full w-full">
                    <img
                      src={`/img/${p.id}/`}
                      alt={p.alt ?? p.caption}
                      loading="lazy"
                      class:list={[
                        "absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105",
                        { "opacity-40": p.hidden },
                      ]}
                    />
                    {p.hidden && (
                      <span class="absolute right-1.5 top-1.5 z-10 rounded bg-black/70 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-white">
                        Skrytá
                      </span>
                    )}
                    <span class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 to-transparent px-2 py-1.5">
                      <span class="block truncate text-xs text-white">
                        {p.caption || "Bez názvu"}
                      </span>
                      <span class="block text-[10px] text-white/70">
                        👁 {p.views} zobrazení
                      </span>
                    </span>
                  </a>
                  <label
                    class="absolute left-1.5 top-1.5 z-10 flex h-7 w-7 cursor-pointer items-center justify-center rounded-md bg-black/50 backdrop-blur-sm"
                    title="Vybrat fotku"
                  >
                    <input
                      type="checkbox"
                      class="photo-check h-4 w-4 cursor-pointer"
                      value={p.id}
                    />
                  </label>
                </div>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>

  <script>
    import { toast } from "../../lib/admin-toast";

    function setup() {
      const root = document.getElementById("photos-manager");
      if (!root || root.dataset.bound) return;
      root.dataset.bound = "1";

      const selectAll = root.querySelector<HTMLInputElement>("#select-all");
      const countEl = root.querySelector<HTMLElement>("#sel-count");
      const delBtn = root.querySelector<HTMLButtonElement>("#bulk-delete");
      const dlBtn = root.querySelector<HTMLButtonElement>("#bulk-download");
      const hideBtn = root.querySelector<HTMLButtonElement>("#bulk-hide");
      const showBtn = root.querySelector<HTMLButtonElement>("#bulk-show");
      const actionBtns = [delBtn, dlBtn, hideBtn, showBtn];
      const checks = () =>
        Array.from(root.querySelectorAll<HTMLInputElement>(".photo-check"));

      function selectedIds(): string[] {
        return checks()
          .filter((c) => c.checked)
          .map((c) => c.value);
      }

      function refresh() {
        const all = checks();
        const sel = all.filter((c) => c.checked);
        if (countEl) countEl.textContent = `Vybráno ${sel.length}`;
        actionBtns.forEach((b) => {
          if (b) b.disabled = sel.length === 0;
        });
        if (selectAll) {
          selectAll.checked = sel.length > 0 && sel.length === all.length;
          selectAll.indeterminate = sel.length > 0 && sel.length < all.length;
        }
      }

      async function setVisibility(hidden: boolean) {
        const ids = selectedIds();
        if (ids.length === 0) return;
        try {
          const res = await fetch("/api/sprava/photos/visibility/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ ids, hidden }),
          });
          if (!res.ok) throw new Error("Akce selhala.");
          toast(hidden ? "Fotky vypnuty." : "Fotky zapnuty.", "success");
          setTimeout(() => location.reload(), 400);
        } catch (err) {
          toast(err instanceof Error ? err.message : "Chyba.", "error");
        }
      }

      dlBtn?.addEventListener("click", async () => {
        const ids = selectedIds();
        if (ids.length === 0) return;
        dlBtn.disabled = true;
        const label = dlBtn.textContent;
        dlBtn.textContent = "Připravuji…";
        try {
          const res = await fetch("/api/sprava/photos/download/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ ids }),
          });
          if (!res.ok) throw new Error("Stažení selhalo.");
          const blob = await res.blob();
          const url = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = url;
          a.download = "fotky.zip";
          document.body.appendChild(a);
          a.click();
          a.remove();
          URL.revokeObjectURL(url);
          toast(`Staženo ${ids.length} fotek.`, "success");
        } catch (err) {
          toast(err instanceof Error ? err.message : "Chyba.", "error");
        } finally {
          dlBtn.disabled = false;
          dlBtn.textContent = label;
        }
      });

      hideBtn?.addEventListener("click", () => setVisibility(true));
      showBtn?.addEventListener("click", () => setVisibility(false));

      selectAll?.addEventListener("change", () => {
        checks().forEach((c) => (c.checked = selectAll.checked));
        refresh();
      });
      checks().forEach((c) => c.addEventListener("change", refresh));

      delBtn?.addEventListener("click", async () => {
        const ids = selectedIds();
        if (ids.length === 0) return;
        if (!confirm(`Opravdu smazat ${ids.length} fotek? Nelze vrátit.`)) return;
        delBtn.disabled = true;
        delBtn.textContent = "Mažu…";
        try {
          const res = await fetch("/api/sprava/photos/bulk-delete/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ ids }),
          });
          const j = (await res.json().catch(() => ({}))) as {
            error?: string;
            deleted?: number;
          };
          if (!res.ok) throw new Error(j.error || "Mazání selhalo.");
          toast(`Smazáno ${j.deleted} fotek.`, "success");
          setTimeout(() => location.reload(), 400);
        } catch (err) {
          toast(err instanceof Error ? err.message : "Chyba.", "error");
          delBtn.disabled = false;
          delBtn.textContent = "Smazat vybrané";
        }
      });

      refresh();
    }

    document.addEventListener("astro:page-load", setup);
  </script>
</AdminLayout>
