---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb, schema } from "../../db";

// Administrace. Přístup chrání Cloudflare Access na hraně + middleware (JWT). Sem
// se dostane jen ověřený admin. Shell (sidebar, nav) řeší AdminLayout.
let galleriesCount = 0;
let photosCount = 0;
let dbError = "";
try {
  const db = await getDb();
  galleriesCount = (await db.select().from(schema.galleries)).length;
  photosCount = (await db.select().from(schema.photos)).length;
} catch (e) {
  dbError = e instanceof Error ? e.message : String(e);
}

const metadata = {
  title: "Administrace",
  description: "Správa fotografií a galerií.",
};
---

<AdminLayout {metadata}>
  <section>
    <div class="mx-auto max-w-3xl">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-2">
        Administrace
      </h1>
      <p class="text-muted-foreground mb-10">
        Správa fotografií, galerií, tipů, blogu a textů webu.
      </p>

      {
        dbError && (
          <div class="mb-8 rounded-lg border border-red-500/40 bg-red-500/10 p-4 text-sm">
            <p class="font-semibold text-red-500">Databáze není dostupná</p>
            <p class="text-muted-foreground mt-1">{dbError}</p>
          </div>
        )
      }

      <div class="grid grid-cols-2 gap-3 mb-10">
        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-3xl font-bold">{photosCount}</p>
          <p class="text-sm text-muted-foreground">fotek</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-3xl font-bold">{galleriesCount}</p>
          <p class="text-sm text-muted-foreground">galerií</p>
        </div>
      </div>

      <a
        href="/sprava/napoveda/"
        class="mb-6 flex items-center justify-between rounded-lg border border-primary/30 bg-primary/5 px-5 py-4 transition-colors hover:border-primary"
      >
        <span>
          <span class="block font-medium">📖 Nápověda — návody ke všemu</span>
          <span class="block text-sm text-muted-foreground"
            >Fotky, galerie, blog, newsletter, texty, pozadí…</span
          >
        </span>
        <span class="text-muted-foreground">&rarr;</span>
      </a>

      <nav class="space-y-2" aria-label="Sekce administrace">
        <a
          href="/sprava/upload/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Nahrát fotky</span>
            <span class="block text-sm text-muted-foreground"
              >Jednotlivě i dávkou</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/photos/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Fotky</span>
            <span class="block text-sm text-muted-foreground"
              >Zařazení do galerií, hlavní fotka, texty, EXIF</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/galleries/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Galerie</span>
            <span class="block text-sm text-muted-foreground"
              >Vytvořit a upravit galerie (sekce)</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/stats/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Statistiky</span>
            <span class="block text-sm text-muted-foreground"
              >Zobrazení fotek, žebříček nejprohlíženějších</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/tips/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Tipy / Aktuálně</span>
            <span class="block text-sm text-muted-foreground"
              >Upoutávky na homepage</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/articles/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Blog / články</span>
            <span class="block text-sm text-muted-foreground"
              >Psaní a úprava článků (Markdown)</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/newsletter/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Newsletter</span>
            <span class="block text-sm text-muted-foreground"
              >Rozeslání novinek odběratelům</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/hero/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Pozadí hlavní stránky</span>
            <span class="block text-sm text-muted-foreground"
              >Fotka pozadí + průhlednost, tonalita, filtry</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/texts/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Texty webu</span>
            <span class="block text-sm text-muted-foreground"
              >Hero podtitul, kontakt, nadpisy sekcí</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/zamek/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Zámek webu</span>
            <span class="block text-sm text-muted-foreground"
              >Zobrazit jen úvodní fotku a text</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
        <a
          href="/sprava/heslo/"
          class="flex items-center justify-between rounded-lg border border-border bg-card px-5 py-4 transition-colors hover:border-primary"
        >
          <span>
            <span class="block font-medium">Změnit heslo</span>
            <span class="block text-sm text-muted-foreground"
              >Nové heslo pro admin účet</span
            >
          </span>
          <span class="text-muted-foreground">&rarr;</span>
        </a>
      </nav>
    </div>
  </section>
</AdminLayout>
