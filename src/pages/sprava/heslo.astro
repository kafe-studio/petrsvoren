---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDb, schema } from "../../db";
import { SUPERADMIN } from "../../lib/auth";

const current = Astro.locals.adminEmail;
const isSuper = current === SUPERADMIN;

const db = await getDb();
// Superadmin vidí všechny účty; ostatní jen svůj.
const users = isSuper
  ? await db.select({ username: schema.adminUsers.username }).from(schema.adminUsers)
  : [{ username: current ?? "" }];
const metadata = { title: "Změna hesla", description: "Změna hesla uživatele." };
const inputCls =
  "w-full rounded-lg border border-border bg-card px-3 py-2 text-sm focus:border-primary focus:outline-none";
---

<AdminLayout {metadata}>
  <div class="mx-auto max-w-md">
    <h1 class="text-3xl font-extrabold tracking-tight mb-2">Změna hesla</h1>
    <p class="text-muted-foreground mb-8">Nastav nové heslo pro admin účet.</p>

    <form id="pw-form" class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1">Uživatel</label>
        {
          isSuper ? (
            <select name="username" class={inputCls}>
              {users.map((u) => (
                <option value={u.username} selected={u.username === current}>
                  {u.username}
                </option>
              ))}
            </select>
          ) : (
            <>
              <input type="hidden" name="username" value={current} />
              <p class="rounded-lg border border-border bg-card px-3 py-2 text-sm text-muted-foreground">
                {current}
              </p>
            </>
          )
        }
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Nové heslo (min. 8 znaků)</label>
        <div class="relative">
          <input id="pw1" name="password" type="password" minlength="8" autocomplete="new-password" class={`${inputCls} pr-11`} required />
          <button type="button" data-toggle-pw="pw1" aria-label="Zobrazit/skrýt heslo" title="Zobrazit/skrýt heslo" class="absolute inset-y-0 right-0 flex items-center px-3 text-muted-foreground hover:text-foreground">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Nové heslo znovu</label>
        <div class="relative">
          <input id="pw2" name="password2" type="password" minlength="8" autocomplete="new-password" class={`${inputCls} pr-11`} required />
          <button type="button" data-toggle-pw="pw2" aria-label="Zobrazit/skrýt heslo" title="Zobrazit/skrýt heslo" class="absolute inset-y-0 right-0 flex items-center px-3 text-muted-foreground hover:text-foreground">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button type="submit" class="btn-primary">Uložit heslo</button>
        <span id="pw-status" class="text-sm text-muted-foreground"></span>
      </div>
    </form>
  </div>

  <script>
    import { toast } from "../../lib/admin-toast";
    function bind() {
      const form = document.getElementById("pw-form") as HTMLFormElement | null;
      if (!form || form.dataset.bound) return;
      form.dataset.bound = "1";
      const status = document.getElementById("pw-status");
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        const password = String(fd.get("password") ?? "");
        if (password !== String(fd.get("password2") ?? "")) {
          toast("Hesla se neshodují.", "error");
          return;
        }
        if (status) status.textContent = "Ukládám…";
        try {
          const res = await fetch("/api/sprava/password/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ username: fd.get("username"), password }),
          });
          const j = (await res.json().catch(() => ({}))) as { error?: string };
          if (!res.ok) throw new Error(j.error || "Uložení selhalo.");
          if (status) status.textContent = "Heslo změněno ✓";
          form.reset();
          toast("Heslo změněno.", "success");
        } catch (err) {
          if (status) status.textContent = "";
          toast(err instanceof Error ? err.message : "Chyba.", "error");
        }
      });
    }
    document.addEventListener("astro:page-load", bind);
  </script>
</AdminLayout>
