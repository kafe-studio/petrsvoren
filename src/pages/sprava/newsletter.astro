---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import NewsletterComposer from "../../components/admin/NewsletterComposer.svelte";
import { desc } from "drizzle-orm";
import { getDb, schema } from "../../db";

const db = await getDb();
const subs = await db
  .select()
  .from(schema.subscribers)
  .orderBy(desc(schema.subscribers.createdAt));
const confirmedCount = subs.filter((s) => s.confirmed).length;
const pendingCount = subs.length - confirmedCount;
const metadata = { title: "Newsletter", description: "Rozesílání novinek." };
const inputCls =
  "w-full rounded-lg border border-border bg-card px-3 py-2 text-sm focus:border-primary focus:outline-none";
---

<AdminLayout {metadata}>
  <div class="mx-auto max-w-2xl">
    <h1 class="text-3xl font-extrabold tracking-tight mb-2">Newsletter</h1>
    <p class="text-muted-foreground mb-4">
      <strong>{confirmedCount}</strong> potvrzených{
        pendingCount > 0 ? `, ${pendingCount} nepotvrzených` : ""
      }. Odesílací adresu nastav v
      <a href="/sprava/texts/" class="underline">Texty webu</a>.
    </p>

    <form id="add-sub" class="mb-8 flex gap-2">
      <input
        name="email"
        type="email"
        required
        placeholder="Přidat adresáta (e-mail) — rovnou potvrzený"
        class={`${inputCls} flex-1`}
      />
      <button type="submit" class="btn-primary shrink-0">Přidat</button>
    </form>

    <NewsletterComposer client:only="svelte" {confirmedCount} />

    <details class="mt-10" open={subs.length > 0}>
      <summary class="cursor-pointer text-sm font-medium">
        Odběratelé ({subs.length})
      </summary>
      <ul class="mt-3 space-y-1 text-sm">
        {
          subs.map((s) => (
            <li class="flex items-center justify-between gap-3 border-b border-border/60 py-1">
              <span class="min-w-0 truncate">
                <span class="text-muted-foreground">{s.email}</span>
                {!s.confirmed && (
                  <span class="ml-2 rounded bg-amber-500/15 px-1.5 py-0.5 text-[10px] font-medium text-amber-600">
                    nepotvrzeno
                  </span>
                )}
              </span>
              <button
                type="button"
                class="shrink-0 text-xs text-red-500 hover:underline"
                data-del-sub={s.id}
              >
                Odebrat
              </button>
            </li>
          ))
        }
        {subs.length === 0 && <li class="text-muted-foreground">Zatím nikdo.</li>}
      </ul>
    </details>
  </div>

  <script>
    import { toast } from "../../lib/admin-toast";
    function bind() {
      const addForm = document.getElementById("add-sub") as HTMLFormElement | null;
      if (addForm && !addForm.dataset.bound) {
        addForm.dataset.bound = "1";
        addForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const email = new FormData(addForm).get("email");
          try {
            const res = await fetch("/api/sprava/newsletter/add/", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ email }),
            });
            const j = (await res.json().catch(() => ({}))) as { error?: string };
            if (!res.ok) throw new Error(j.error || "Přidání selhalo.");
            toast("Adresát přidán.", "success");
            setTimeout(() => location.reload(), 400);
          } catch (err) {
            toast(err instanceof Error ? err.message : "Chyba.", "error");
          }
        });
      }

      document.querySelectorAll<HTMLElement>("[data-del-sub]").forEach((b) => {
        if (b.dataset.bound) return;
        b.dataset.bound = "1";
        b.addEventListener("click", async () => {
          const id = b.getAttribute("data-del-sub");
          if (!confirm("Odebrat tohoto adresáta?")) return;
          try {
            const res = await fetch(`/api/sprava/newsletter/${id}/`, {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
              body: "{}",
            });
            if (!res.ok) throw new Error("Odebrání selhalo.");
            toast("Adresát odebrán.", "success");
            setTimeout(() => location.reload(), 300);
          } catch (err) {
            toast(err instanceof Error ? err.message : "Chyba.", "error");
          }
        });
      });
    }
    document.addEventListener("astro:page-load", bind);
  </script>
</AdminLayout>
