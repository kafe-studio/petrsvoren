---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import ArticleEditor from "../../../components/admin/ArticleEditor.svelte";
import { eq, desc } from "drizzle-orm";
import { getDb, schema } from "../../../db";
import { siteConfig } from "../../../config/site";

const id = Astro.params.id ?? "";
const db = await getDb();
const a = await db
  .select()
  .from(schema.articles)
  .where(eq(schema.articles.id, id))
  .get();
if (!a) return Astro.rewrite("/404");

// Fotky pro vkládání z galerie + stránky webu pro odkazy.
const photoRows = await db
  .select({ id: schema.photos.id, caption: schema.photos.caption })
  .from(schema.photos)
  .orderBy(desc(schema.photos.createdAt));
const galleryPhotos = photoRows.map((p) => ({
  id: p.id,
  caption: p.caption || "Bez názvu",
}));

const articleRows = await db
  .select({ slug: schema.articles.slug, title: schema.articles.title })
  .from(schema.articles);
const sitePages = [
  { label: "Domů", href: "/" },
  ...siteConfig.sections.map((s) => ({ label: s.title, href: `/${s.slug}/` })),
  { label: "Výběr měsíce", href: "/mesic/" },
  { label: "Blog", href: "/blog/" },
  { label: "Kontakt", href: "/kontakt/" },
  ...articleRows.map((r) => ({
    label: `Článek: ${r.title}`,
    href: `/blog/${r.slug}/`,
  })),
];

let tags = "";
if (a.tags) {
  try {
    const p = JSON.parse(a.tags);
    if (Array.isArray(p)) tags = p.join(", ");
  } catch {
    /* ignoruj */
  }
}

const article = {
  id: a.id,
  title: a.title,
  slug: a.slug,
  description: a.description,
  author: a.author,
  pubDate: a.pubDate ? a.pubDate.toISOString().slice(0, 10) : "",
  category: a.category ?? "",
  tags,
  body: a.body ?? "",
  hasImage: Boolean(a.r2Key),
};
const metadata = { title: `Článek: ${a.title}`, description: "Editace článku." };
---

<AdminLayout {metadata}>
  <div class="mx-auto max-w-2xl">
    <a href="/sprava/articles/" class="text-sm text-muted-foreground hover:underline">&larr; Všechny články</a>
    <h1 class="text-2xl font-extrabold tracking-tight mt-2 mb-6">Upravit článek</h1>
    <ArticleEditor
      client:only="svelte"
      {article}
      photos={galleryPhotos}
      pages={sitePages}
    />
  </div>
</AdminLayout>
