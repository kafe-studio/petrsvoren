---
export const prerender = true;
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const metadata = {
  title: "Kontakt",
  description: `Kontakt na ${siteConfig.author}, e-mail a Facebook.`,
};
---

<BaseLayout {metadata}>
  <section class="pt-28 pb-24 px-6">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-6 reveal">Kontakt</h1>
      <p class="text-muted-foreground leading-relaxed mb-10 reveal">
        Máte zájem o fotografii, výstavu nebo se jen chcete na něco zeptat?
        Napište mi e-mail nebo zprávu na Facebooku.
      </p>
      <ul class="space-y-4 reveal">
        <li>
          <a
            href={`mailto:${siteConfig.email}`}
            class="inline-flex items-center gap-3 text-lg text-foreground hover:text-primary transition-colors"
          >
            <Icon name="lucide:mail" class="h-5 w-5" />
            {siteConfig.email}
          </a>
        </li>
        {
          siteConfig.socialLinks.facebook && (
            <li>
              <a
                href={siteConfig.socialLinks.facebook}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 text-lg text-foreground hover:text-primary transition-colors"
              >
                <Icon name="lucide:facebook" class="h-5 w-5" />
                Facebook
              </a>
            </li>
          )
        }
      </ul>
    </div>
  </section>
</BaseLayout>
