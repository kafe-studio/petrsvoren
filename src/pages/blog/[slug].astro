---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/seo/Schema.astro";
import { getArticleBySlug } from "../../lib/content";

const slug = Astro.params.slug ?? "";
const post = await getArticleBySlug(slug);
if (!post) return Astro.rewrite("/404");

const { title, description, pubDate, author, imageId } = post;
const image = imageId ? `/img/${imageId}/` : undefined;
// Tělo článku je uložené jako HTML (ProseKit editor).
const html = post.body ?? "";
const metadata = { title, description };
---

<BaseLayout {metadata}>
  <Schema
    slot="head"
    type="BlogPosting"
    data={{
      title,
      description,
      image,
      pubDate: pubDate ?? undefined,
      author,
      url: Astro.url.href,
    }}
  />
  <article class="pt-32 pb-16 px-6">
    <div class="mx-auto max-w-3xl">
      <header class="mb-10 reveal">
        <h1 class="text-4xl font-extrabold mb-4">{title}</h1>
        <p class="text-sm text-muted-foreground">
          {
            pubDate && (
              <time datetime={pubDate.toISOString()}>
                {pubDate.toLocaleDateString("cs")}
              </time>
            )
          }
          {author && <span> &middot; {author}</span>}
        </p>
      </header>
      <div class="prose prose-neutral dark:prose-invert max-w-none reveal" set:html={html} />
      <div class="mt-12 pt-8 border-t border-border">
        <a href="/blog/" class="btn-outline py-2 px-6 text-sm">Zpět na blog</a>
      </div>
    </div>
  </article>
</BaseLayout>
