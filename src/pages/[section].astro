---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import PhotoGrid from "../components/gallery/PhotoGrid.astro";
import { getGallery, getSectionPhotos } from "../lib/content";

// Galerie sekce z D1 (galleries + photo_galleries). Title/description editovatelné v adminu.
const slug = Astro.params.section ?? "";
const gallery = await getGallery(slug);
if (!gallery) return Astro.rewrite("/404");

const photos = await getSectionPhotos(slug);
const title = gallery.title;
const metadata = {
  title,
  description: gallery.description ?? `Fotografie: ${title}`,
};
---

<BaseLayout {metadata}>
  <section class="pt-28 pb-24 px-6">
    <div class="mx-auto max-w-7xl">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-10 reveal">
        {title}
      </h1>
      {
        photos.length === 0 ? (
          <p class="text-muted-foreground reveal">
            Tato sekce zatím nemá žádné fotografie.
          </p>
        ) : (
          <PhotoGrid photos={photos} />
        )
      }
    </div>
  </section>
</BaseLayout>
