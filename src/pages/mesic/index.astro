---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { monthLabel, sortMonthsDesc } from "../../config/monthly";
import { getAlbumMonths, getTexts, txt } from "../../lib/content";

// Přehled měsíčních výběrů z D1 — mřížka dlaždic, jedna na měsíc (nejnovější první).
const albumsRaw = await getAlbumMonths();
const texts = await getTexts();
const byMonth = new Map(albumsRaw.map((a) => [a.month, a]));
const months = sortMonthsDesc(albumsRaw.map((a) => a.month));

const albums = months.map((month) => {
  const a = byMonth.get(month);
  return {
    month,
    label: monthLabel(month),
    coverId: a?.coverId ?? null,
    count: a?.count ?? 0,
  };
});

const fotky = (n: number) =>
  n === 1 ? "fotka" : n >= 2 && n <= 4 ? "fotky" : "fotek";

const heading = txt(texts, "mesic_heading", "Výběr měsíce");
const intro = txt(
  texts,
  "mesic_text",
  "Galerie sestavené po měsících. Vyber měsíc a prohlédni si výběr.",
);
const metadata = {
  title: heading,
  description: "Měsíční výběry fotografií Petra Svoreně — galerie po měsících.",
};
---

<BaseLayout {metadata}>
  <section class="pt-28 pb-24 px-6">
    <div class="mx-auto max-w-5xl">
      <h1
        class="text-3xl md:text-4xl font-extrabold tracking-tight mb-3 reveal"
      >
        {heading}
      </h1>
      <p class="text-muted-foreground mb-10 reveal">
        {intro}
      </p>

      {
        albums.length === 0 ? (
          <p class="text-muted-foreground reveal">
            Zatím tu nejsou žádné měsíční výběry.
          </p>
        ) : (
          <nav
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 reveal"
            aria-label="Měsíční výběry"
          >
            {albums.map((a) => (
              <a
                href={`/mesic/${a.month}/`}
                class="group relative flex items-end overflow-hidden rounded-sm bg-neutral-900 aspect-[4/3]"
              >
                {a.coverId && (
                  <img
                    src={`/img/${a.coverId}/`}
                    alt={`Výběr ${a.label}`}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                )}
                <span
                  class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/25 to-transparent"
                  aria-hidden="true"
                />
                <span
                  class="absolute inset-0 bg-white/0 transition-colors duration-300 group-hover:bg-white/15"
                  aria-hidden="true"
                />
                <span class="relative z-10 flex w-full items-end justify-between px-5 py-4">
                  <span>
                    <span class="block text-xl font-semibold tracking-tight text-white">
                      {a.label}
                    </span>
                    <span class="block text-sm text-white/70">
                      {a.count} {fotky(a.count)}
                    </span>
                  </span>
                  <span class="text-white/70 transition-transform group-hover:translate-x-1">
                    &rarr;
                  </span>
                </span>
              </a>
            ))}
          </nav>
        )
      }
    </div>
  </section>
</BaseLayout>
