---
export const prerender = true;
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { monthLabel, monthShort, monthOrdinal } from "../../config/monthly";

// Časová osa měsíčních výběrů. Měsíce vzestupně (nejstarší vlevo → nejnovější vpravo),
// poloha na ose je proporční ke skutečnému času (rozestup = počet měsíců mezi nimi).
// Posuvník (scrubber) přepíná velký náhled; výchozí pozice = nejnovější měsíc.
const all = await getCollection("monthly");
const months = [...new Set(all.map((p) => p.data.month))].sort(
  (a, b) => monthOrdinal(a) - monthOrdinal(b),
);
const first = monthOrdinal(months[0] ?? "");
const last = monthOrdinal(months[months.length - 1] ?? "");
const span = last - first; // 0 = jediný měsíc → náhled doprostřed osy

const stops = months.map((month) => {
  const photos = all
    .filter((p) => p.data.month === month)
    .sort((a, b) => a.data.order - b.data.order);
  return {
    month,
    label: monthLabel(month),
    short: monthShort(month),
    year: month.slice(0, 4),
    cover: photos[0]?.data.cover,
    count: photos.length,
    pct: span > 0 ? ((monthOrdinal(month) - first) / span) * 100 : 50,
  };
});
const initial = stops.length - 1; // nejnovější měsíc je vpravo

// České skloňování "fotka / fotky / fotek".
const fotky = (n: number) =>
  n === 1 ? "fotka" : n >= 2 && n <= 4 ? "fotky" : "fotek";

const metadata = {
  title: "Po měsících",
  description: "Měsíční výběr fotografií Petra Svoreně na časové ose.",
};
---

<BaseLayout {metadata}>
  <section class="pt-28 pb-24 px-6">
    <div class="mx-auto max-w-5xl">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-10 reveal">Po měsících</h1>

      {
        stops.length === 0 ? (
          <p class="text-muted-foreground reveal">Zatím tu nejsou žádné měsíční výběry.</p>
        ) : (
          <div class="reveal" data-timeline>
            {/* Velký náhled — karty všech měsíců nad sebou, viditelná je aktivní. */}
            <div class="mt-stage">
              {stops.map((s, i) => (
                <a
                  href={`/mesic/${s.month}/`}
                  class:list={["mt-card", { "is-active": i === initial }]}
                  data-card={i}
                  aria-hidden={i === initial ? undefined : "true"}
                  tabindex={i === initial ? undefined : -1}
                >
                  {s.cover && (
                    <Image
                      src={s.cover}
                      alt={`Výběr ${s.label}`}
                      widths={[640, 1280]}
                      sizes="(min-width: 1024px) 64rem, 100vw"
                      loading={i === initial ? "eager" : "lazy"}
                      class="mt-card-img"
                    />
                  )}
                  <span class="mt-card-grad" aria-hidden="true" />
                  <span class="mt-card-meta">
                    <span class="mt-card-label">{s.label}</span>
                    <span class="mt-card-sub">
                      {s.count} {fotky(s.count)} · Otevřít galerii &rarr;
                    </span>
                  </span>
                </a>
              ))}
            </div>

            {/* Časová osa se scrubberem. Ticky jsou odkazy → fungují i bez JS. */}
            <div class="mt-axis" role="group" aria-label="Časová osa měsíců">
              <div class="mt-rail">
                <span class="mt-line" aria-hidden="true" />
                <span
                  class="mt-handle"
                  data-handle
                  role="slider"
                  tabindex="0"
                  aria-label="Posuvník měsíců"
                  aria-valuemin="0"
                  aria-valuemax={stops.length - 1}
                  aria-valuenow={initial}
                  aria-valuetext={stops[initial].label}
                  style={`left:${stops[initial].pct}%`}
                />
                {stops.map((s, i) => (
                  <a
                    href={`/mesic/${s.month}/`}
                    class:list={["mt-tick", { "is-active": i === initial }]}
                    data-tick={i}
                    data-pct={s.pct}
                    style={`left:${s.pct}%`}
                    aria-label={s.label}
                  >
                    <span class="mt-dot" aria-hidden="true" />
                    <span class="mt-tick-label">
                      {s.short} <span class="mt-tick-year">{s.year}</span>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<script>
  // Interaktivní časová osa: scrubber přepíná velký náhled. Vanilla JS (stejný
  // přístup jako galerie PhotoGrid), Astro-optimalizované obrázky jsou předrenderované.
  function setupTimeline(root: HTMLElement) {
    if (root.dataset.bound) return;
    root.dataset.bound = "1";

    const handleRef = root.querySelector<HTMLElement>("[data-handle]");
    const railRef = root.querySelector<HTMLElement>(".mt-rail");
    const ticks = Array.from(root.querySelectorAll<HTMLElement>("[data-tick]"));
    const cards = Array.from(root.querySelectorAll<HTMLElement>("[data-card]"));
    if (!handleRef || !railRef || ticks.length === 0) return;
    // Ne-null aliasy — TS neztenčí original uvnitř vnořených funkcí (closure).
    const handle: HTMLElement = handleRef;
    const rail: HTMLElement = railRef;

    const pcts = ticks.map((t) => Number(t.dataset.pct) || 0);
    let current = cards.findIndex((c) => c.classList.contains("is-active"));
    if (current < 0) current = ticks.length - 1;

    function select(index: number) {
      const i = Math.max(0, Math.min(ticks.length - 1, index));
      current = i;
      cards.forEach((c, ci) => {
        const on = ci === i;
        c.classList.toggle("is-active", on);
        if (on) {
          c.removeAttribute("aria-hidden");
          c.removeAttribute("tabindex");
        } else {
          c.setAttribute("aria-hidden", "true");
          c.setAttribute("tabindex", "-1");
        }
      });
      ticks.forEach((t, ti) => t.classList.toggle("is-active", ti === i));
      handle.style.left = `${pcts[i]}%`;
      handle.setAttribute("aria-valuenow", String(i));
      const label = ticks[i].getAttribute("aria-label") ?? "";
      handle.setAttribute("aria-valuetext", label);
    }

    // Nejbližší měsíc k poměrné poloze (0–100) podél osy.
    function nearest(pct: number) {
      let best = 0;
      let bestDist = Infinity;
      pcts.forEach((p, i) => {
        const d = Math.abs(p - pct);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      });
      return best;
    }

    function pctFromClientX(clientX: number) {
      const rect = rail.getBoundingClientRect();
      if (!rect.width) return 0;
      return ((clientX - rect.left) / rect.width) * 100;
    }

    let dragging = false;
    function pointerScrub(e: PointerEvent) {
      select(nearest(pctFromClientX(e.clientX)));
    }

    handle.addEventListener("pointerdown", (e) => {
      dragging = true;
      handle.setPointerCapture?.(e.pointerId);
      e.preventDefault();
    });
    handle.addEventListener("pointermove", (e) => {
      if (dragging) pointerScrub(e);
    });
    const endDrag = (e: PointerEvent) => {
      if (dragging) handle.releasePointerCapture?.(e.pointerId);
      dragging = false;
    };
    handle.addEventListener("pointerup", endDrag);
    handle.addEventListener("pointercancel", endDrag);

    // Klik kamkoli na osu → skok na nejbližší měsíc.
    rail.addEventListener("pointerdown", (e) => {
      if (e.target === handle) return;
      select(nearest(pctFromClientX(e.clientX)));
    });

    // Klik na tick (s JS) jen vybere náhled — neotvírá galerii (od toho je velká karta).
    ticks.forEach((t, i) => {
      t.addEventListener("click", (e) => {
        e.preventDefault();
        select(i);
      });
    });

    // Klávesnice na handle (role=slider).
    handle.addEventListener("keydown", (e) => {
      let next = current;
      if (e.key === "ArrowLeft" || e.key === "ArrowDown") next = current - 1;
      else if (e.key === "ArrowRight" || e.key === "ArrowUp") next = current + 1;
      else if (e.key === "Home") next = 0;
      else if (e.key === "End") next = ticks.length - 1;
      else if (e.key === "Enter") {
        const href = ticks[current].getAttribute("href");
        if (href) location.href = href;
        return;
      } else return;
      e.preventDefault();
      select(next);
    });
  }

  document.addEventListener("astro:page-load", () => {
    document
      .querySelectorAll<HTMLElement>("[data-timeline]")
      .forEach(setupTimeline);
  });
</script>

<style>
  /* Velký náhled aktivního měsíce — karty se překrývají, přepíná se krytí. */
  .mt-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 0.125rem;
    background: rgb(23 23 23);
  }
  .mt-card {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  .mt-card.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .mt-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .mt-card.is-active:hover .mt-card-img {
    transform: scale(1.04);
  }
  .mt-card-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgb(0 0 0 / 0.78),
      rgb(0 0 0 / 0.25) 45%,
      transparent
    );
  }
  .mt-card-meta {
    position: relative;
    z-index: 1;
    padding: 1.25rem 1.5rem;
    color: #fff;
  }
  .mt-card-label {
    display: block;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }
  .mt-card-sub {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.8rem;
    color: rgb(255 255 255 / 0.75);
  }

  /* Časová osa. Vnitřní lišta má odsazení, aby krajní ticky a popisky nepřetekly. */
  .mt-axis {
    margin-top: 1.75rem;
    padding-inline: 1.25rem;
  }
  .mt-rail {
    position: relative;
    height: 3.25rem;
    cursor: pointer;
  }
  .mt-line {
    position: absolute;
    left: 0;
    right: 0;
    top: 0.5rem;
    height: 1px;
    background: color-mix(in srgb, currentColor 22%, transparent);
    color: var(--muted-foreground, #888);
  }
  .mt-tick {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--muted-foreground, #888);
  }
  .mt-dot {
    width: 7px;
    height: 7px;
    margin-top: calc(0.5rem - 3px);
    border-radius: 9999px;
    background: color-mix(in srgb, currentColor 45%, transparent);
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }
  .mt-tick:hover .mt-dot {
    background: currentColor;
  }
  .mt-tick.is-active .mt-dot {
    background: var(--foreground, #111);
    transform: scale(1.5);
  }
  .mt-tick-label {
    margin-top: 0.55rem;
    font-size: 0.7rem;
    line-height: 1;
    white-space: nowrap;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  .mt-tick.is-active .mt-tick-label {
    opacity: 1;
    color: var(--foreground, #111);
    font-weight: 600;
  }
  .mt-tick-year {
    opacity: 0.6;
  }

  /* Jezdec scrubberu. */
  .mt-handle {
    position: absolute;
    top: 0.5rem;
    transform: translate(-50%, -50%);
    width: 16px;
    height: 16px;
    border-radius: 9999px;
    background: var(--foreground, #111);
    box-shadow: 0 0 0 4px var(--background, #fff);
    cursor: grab;
    touch-action: none;
    z-index: 2;
    transition: left 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mt-handle:active {
    cursor: grabbing;
  }
  .mt-handle:focus-visible {
    outline: 2px solid var(--primary, #555);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .mt-card,
    .mt-card-img,
    .mt-handle,
    .mt-dot {
      transition: none;
    }
  }
</style>
