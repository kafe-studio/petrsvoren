---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import PhotoGrid from "../../components/gallery/PhotoGrid.astro";
import MonthAxis from "../../components/gallery/MonthAxis.astro";
import { monthLabel } from "../../config/monthly";
import { getMonthPhotos } from "../../lib/content";

// Jedna stránka na měsíc. Fotky z D1 podle photos.month, řazené dle sort_order.
const month = Astro.params.month ?? "";
if (!/^\d{4}-\d{2}$/.test(month)) return Astro.rewrite("/404");

const photos = await getMonthPhotos(month);
const label = monthLabel(month);
const metadata = { title: label, description: `Fotografie: ${label}` };
---

<BaseLayout {metadata}>
  <section class="pt-28 pb-24 px-6">
    <div class="mx-auto max-w-7xl">
      <a
        href="/mesic/"
        class="reveal mb-6 inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        &larr; Výběr měsíce
      </a>
      <h1
        class="text-3xl md:text-4xl font-extrabold tracking-tight mb-6 reveal"
      >
        {label}
      </h1>
      <MonthAxis current={month} />
      {
        photos.length === 0 ? (
          <p class="text-muted-foreground reveal">
            Tento měsíc zatím nemá žádné fotografie.
          </p>
        ) : (
          <PhotoGrid photos={photos} />
        )
      }
    </div>
  </section>
</BaseLayout>
