{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp", "--headless"]
    },
    "cf-playwright": {
      "type": "http",
      "url": "https://pw-mcp.testuj.workers.dev/mcp"
    },
    "cloudflare-api": {
      "type": "http",
      "url": "https://mcp.cloudflare.com/mcp",
      "headers": {
        "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
      }
    },
    "worker-mcp": {
      "type": "http",
      "url": "https://worker-mcp.ukazka.workers.dev/mcp"
    }
  }
}
